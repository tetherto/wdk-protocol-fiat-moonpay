{
  "name": "wdk-protocol-fiat-moonpay",
  "version": "1.0.0-beta.1",
  "description": "A simple package that lets @tetherto/wdk-wallet accounts interact with the MoonPay protocol",
  "keywords": [
    "wdk",
    "protocol",
    "fiat",
    "moonpay"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/wdk-protocol-fiat-moonpay.git"
  },
  "license": "Apache-2.0",
  "author": "Tether",
  "type": "module",
  "main": "index.js",
  "types": "./types",
  "scripts": {
    "build:types": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@tetherto/wdk-wallet": "^1.0.0-beta.6",
    "@moonpay/moonpay-node": "0.2.13",
    "bare-node-runtime": "^1.1.4",
    "bignumber.js": "^9.3.1"
  },
  "devDependencies": {
    "cross-env": "7.0.3",
    "jest": "30.1.3",
    "standard": "17.1.2",
    "typescript": "5.8.3"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js"
    ]
  }
}
